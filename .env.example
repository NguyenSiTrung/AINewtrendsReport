# ─── AI News & Trends Report — Environment Configuration ───
# Copy to .env and edit as needed:  cp .env.example .env
# NOTE: Do NOT quote values (e.g. KEY=value, not KEY="value").
#       systemd EnvironmentFile treats quotes as literal characters.

# ─── LLM ──────────────────────────────────────────────────
# OpenAI-compatible endpoint (local LLM server)
AINEWS_LLM_BASE_URL=http://127.0.0.1:8080/v1
AINEWS_LLM_API_KEY=not-needed
AINEWS_LLM_MODEL=local-model
AINEWS_LLM_TEMPERATURE=0.0
AINEWS_LLM_MAX_TOKENS=4096
AINEWS_LLM_TIMEOUT=120
# Optional: JSON dict of extra HTTP headers
# AINEWS_LLM_EXTRA_HEADERS={"X-Custom": "value"}

# ─── Database ─────────────────────────────────────────────
# SQLite path (WAL mode, auto-created on first run)
AINEWS_DB_PATH=./var/ainews.db

# ─── Cache / Broker ───────────────────────────────────────
# Valkey for Celery broker + Tavily cache
AINEWS_VALKEY_URL=redis://127.0.0.1:6379/0

# ─── Search ───────────────────────────────────────────────
# Tavily API key for web search (required for news retrieval)
AINEWS_TAVILY_API_KEY=

# ─── Pipeline ─────────────────────────────────────────────
# Max sources in the final aggregate report (0 = unlimited)
AINEWS_REPORT_MAX_SOURCES=50

# ─── Logging ──────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AINEWS_LOG_LEVEL=INFO

# ─── Security ─────────────────────────────────────────────
# JWT secret for admin sessions. Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# MUST be set for production (sessions won't survive restarts without it)
AINEWS_JWT_SECRET=
